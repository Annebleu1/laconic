// generator client : indique à Prisma de générer les types TypeScript
generator client {
  provider = "prisma-client-js"
}

// datasource db : configuration de la connexion à ta base PostgreSQL
datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

// --- MODÈLES DE DONNÉES ---

model User {
  id            String    @id @default(cuid())
  email         String    @unique
  fullName      String?
  password      String    // Le mot de passe haché (bcrypt)
  role          String    @default("member") // admin ou member
  
  // Relations
  houseId       String?
  house         House?    @relation(fields: [houseId], references: [id])
  expenses      Expense[] // Les dépenses payées par cet utilisateur
  
  createdAt     DateTime  @default(now())
  updatedAt     DateTime  @updatedAt
}

model House {
  id          String    @id @default(cuid())
  name        String
  inviteCode  String    @unique // Code court pour rejoindre la maison
  
  // Relations
  users       User[]
  expenses    Expense[]
  
  createdAt   DateTime  @default(now())
}

model Expense {
  id          String   @id @default(cuid())
  title       String
  amount      Float
  
  // Relations
  paidBy      User     @relation(fields: [userId], references: [id])
  userId      String
  house       House    @relation(fields: [houseId], references: [id])
  houseId     String
  
  createdAt   DateTime @default(now())
}